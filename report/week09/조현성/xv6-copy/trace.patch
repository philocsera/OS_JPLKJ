@@ -95,6 +96,29 @@ sys_kill(void)
   return kkill(pid);
 }
 
+uint64
+sys_sysinfo(void)
+{
+  struct sysinfo info;
+  uint64 addr;
+
+  argaddr(0, &addr);
+  info.freemem = freemem_count();
+  info.nproc = proc_count();
+  if(copyout(myproc()->pagetable, addr, (char *)&info, sizeof(info)) < 0)
+    return -1;
+  return 0;
+}
+
+uint64
+sys_trace(void)
+{
+  int mask;
+  argint(0, &mask);
+  myproc()->trace_mask = mask;
+  return 0;
+}
