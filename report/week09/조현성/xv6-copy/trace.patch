@@ -62,6 +62,23 @@ kfree(void *pa)
   release(&kmem.lock);
 }
 
+// Return the number of bytes of free physical memory.
+uint64
+freemem_count(void)
+{
+  struct run *r;
+  uint64 n = 0;
+
+  acquire(&kmem.lock);
+  r = kmem.freelist;
+  while(r){
+    n++;
+    r = r->next;
+  }
+  release(&kmem.lock);
+  return n * PGSIZE;
+}
+
